# ══════════════════════════════════════════════════════
# Digital Product Shop — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════

# ── DATABASE (required) ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shopkey

# ── JWT AUTH ────────────────────────────────────────
# Leave empty to auto-generate (changes on restart = logs out users)
# Set a fixed value for production
JWT_SECRET=your-random-secret-key-here

# ── ADMIN ───────────────────────────────────────────
# Secret key to promote a user to admin via POST /api/auth/make-admin
ADMIN_SECRET=changeme123

# ── APP ─────────────────────────────────────────────
APP_PORT=3000
APP_BASE_URL=https://your-domain.com

# ── PAYOS (optional — payment gateway) ──────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ── GOOGLE OAUTH (optional) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ── DISCORD OAUTH (optional) ───────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback

# ── TELEGRAM BOT (optional) ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── DISCORD BOT (optional) ─────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ADMIN_CHANNEL_ID=
DISCORD_USER_CHANNEL_ID=

# ── EMAIL / SMTP (optional) ────────────────────────
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
